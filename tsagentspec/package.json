{
  "name": "agentspec",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Oracle Open Agent Specification",
  "license": "UPL-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/oracle/agent-spec.git",
    "directory": "tsagentspec"
  },
  "homepage": "https://github.com/oracle/agent-spec/tree/main/tsagentspec",
  "keywords": [
    "agent",
    "agentspec",
    "oracle",
    "llm",
    "ai"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src tests examples",
    "clean": "rm -rf dist",
    "example": "tsx"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.2",
    "tsup": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "ajv": "6.14.0",
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0",
    "minimatch@^3.0.0": {
      "brace-expansion": "1.1.13"
    },
    "minimatch@^9.0.0": {
      "brace-expansion": "2.0.3"
    },
    "postcss": "8.5.12",
    "vite": "8.0.16"
  }
}
